# macOS
.DS_Store

# IDE local settings
.vscode/
.idea/

# Local secrets and environment variables
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Local-only credentials and private keys
**/secrets/
**/credentials/
**/*.local.*
*.pem
*.key
*.p12
*.pfx

# WeChat drafts and publishing artifacts
daily/**/article.*
daily/**/cover.*
**/*.wechat.html
writing/

# Python local artifacts
**/__pycache__/
**/*.py[cod]
**/.venv/
**/venv/
